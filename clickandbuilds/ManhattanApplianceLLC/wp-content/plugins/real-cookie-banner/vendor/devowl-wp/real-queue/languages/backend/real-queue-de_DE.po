#: queue/Executor.php:1
msgid "Process failed due to an unexpected error."
msgstr "Der Prozess ist aufgrund eines unerwarteten Fehlers fehlgeschlagen."

#. translators:
#: queue/Executor.php:1
msgid "%1$d / %2$d (thereof %3$d remaining) tasks could not be executed properly."
msgstr "%1$d / %2$d (davon %3$d verbleibende) Aufgaben konnten nicht ordnungsgemäß ausgeführt werden."

#: queue/Job.php:1
msgid "The passed callable persisted to the job cannot be called (`is_callable`)"
msgstr "Der übergebene Callable, die im Job persistiert, kann nicht aufgerufen werden (`is_callable`)"

#: queue/Job.php:1
msgid "This job is already running in another thread on your server."
msgstr "Dieser Job läuft bereits in einem anderen Thread auf deinem Server."

#: queue/Job.php:1
msgid "Unexpected exception."
msgstr "Unerwarteter Fehler."
